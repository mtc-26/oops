# MongoDB connection (replace with your Atlas URI)
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/oops?retryWrites=true&w=majority

# JWT secret for sessions (generate: openssl rand -hex 32)
JWT_SECRET=replace-me-32-bytes-of-random-hex

# CORS origin (frontend dev URL)
CORS_ORIGIN=http://localhost:4321

PORT=3100

# Email — choose ONE provider
# EMAIL_PROVIDER=console     (default — OTP shown in backend terminal, no real send)
# EMAIL_PROVIDER=gmail       (uses Gmail SMTP via App Password — send to anyone, 500/day)
#   GMAIL_USER=yourgmail@gmail.com
#   GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_PROVIDER=resend      (Resend API — needs verified domain to send to anyone)
#   RESEND_API_KEY=re_xxx
# EMAIL_FROM=OOPS! <noreply@example.com>
EMAIL_PROVIDER=console
